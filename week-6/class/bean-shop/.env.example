# Bean Shop 환경변수 예시 — 실제 값은 .env 에 넣으세요 (.env 는 절대 커밋 금지)

# Supabase Postgres (pgBouncer transaction pooler, port 6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# JWT 서명 시크릿 (긴 랜덤 문자열)
JWT_SECRET=change-me-to-a-long-random-string

# TossPayments 결제위젯 키
#  - CLIENT KEY (test_gck_... / live_gck_...): 프론트엔드 노출 OK
#  - SECRET KEY (test_gsk_... / live_gsk_...): 서버 전용, 절대 노출 금지
TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6

# ImageKit (프로필 이미지 업로드) — https://imagekit.io Dashboard > Developer > API Keys
#  - URL ENDPOINT, PUBLIC KEY: 프론트 노출 OK
#  - PRIVATE KEY: 서버 전용, 절대 노출 금지
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxxxxxxxxx

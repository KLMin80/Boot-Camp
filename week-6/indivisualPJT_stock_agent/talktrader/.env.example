# ── 톡트레이더 환경변수 견본 ─────────────────────────────
# 이 파일을 복사해 ".env" 로 만들고 값을 채우세요.  (.env 는 절대 커밋 금지)
#   Windows:  copy .env.example .env
#   Git Bash: cp .env.example .env

# [모의/실전] 기본은 모의(false). 실전 전환 게이트 통과 전엔 절대 true 금지.
IS_REAL=false

# [한국투자증권 KIS] 모의투자용 앱키/시크릿 (KIS Developers에서 발급 · "모의용"인지 반드시 확인)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=              # 계좌번호 (예: 50123456-01)

# [텔레그램] @BotFather 로 만든 봇 토큰 + 내 chat_id (Phase 3에서 확인)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 안전장치 한도 (모의라도 실전 기준 습관 들이기) ──────────
DAILY_MAX_ORDERS=10           # 하루 최대 주문 횟수
DAILY_MAX_BUY_AMOUNT=1000000  # 하루 최대 총매수금액(원)
PER_STOCK_MAX_BUY=300000      # 종목당 최대 매수금액(원)
COOLDOWN_SECONDS=60           # 같은 종목 재주문 금지 시간(초)
WHITELIST=005930,000660       # 매매 허용 종목(콤마구분). 비우면 아무것도 매매 안 함

# ── 스탑로스 전략 ──────────────────────────────────────
STOPLOSS_PCT=-3.0             # 매입가 대비 이 % 이하로 떨어지면 손절 (음수)
WATCH_INTERVAL_SECONDS=30     # 보유종목 손익률 감시 주기(초)

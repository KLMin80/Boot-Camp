# 남김없이 — 환경변수 견본 (실제 값 없음. 배포 시 Vercel에 같은 이름으로 설정)
# 로컬은 이 파일을 .env로 복사해 값을 채운다. .env는 절대 커밋 금지(.gitignore).

# --- 필수 ---
# Supabase Postgres 연결 문자열 (Connect → Direct 안 되면 pooler 6543)
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# JWT 서명 키 — `npm run secret`으로 생성하거나 아래 명령으로:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<랜덤 32바이트 hex>

# OpenAI 키 — 레시피 생성 + 라벨 OCR(gpt-4o-mini)
OPEN_AI_API=sk-...

# --- 선택 ---
# 네이버 검색 API — 구매 시트의 참고 최저가 (없으면 딥링크만, 우아하게 degrade)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

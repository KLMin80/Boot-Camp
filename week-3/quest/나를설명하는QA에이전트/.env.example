# Anthropic(Claude) API 키 (실제 .env 파일에 복사한 뒤 값을 채우세요)
# 발급: https://console.anthropic.com/  →  로그인 →  "API Keys" 메뉴
# ⚠️ 실제 .env 는 절대 커밋하지 마세요 (.gitignore 로 제외됨)
ANTHROPIC_API_KEY=여기에_발급받은_키를_붙여넣으세요

# (선택) 사용할 Claude 모델 — 기본 claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# (선택) 서버 포트 — 기본 3000
# PORT=3000
